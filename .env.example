BOT_NAME=Pegasus
DERIV_TOKEN=coloque_seu_token_demo_aqui
DERIV_APP_ID=1089
ACCOUNT_MODE=demo

SYMBOL=R_100
CURRENCY=USD
STAKE=1.00
DURATION=5
DURATION_UNIT=m
GRANULARITY=60
CANDLE_COUNT=260
MIN_SIGNAL_SCORE=5

USE_TREND_FILTER=true
TREND_EMA_WINDOW=200
USE_ATR_FILTER=true
ATR_WINDOW=14
MIN_ATR_PERCENT=0.05
RSI_EXTREME_WEIGHT=3
RSI_SOFT_WEIGHT=1
MACD_CROSS_WEIGHT=3
BOLLINGER_TOUCH_WEIGHT=2
EMA_CROSS_WEIGHT=2
BLOCKED_UTC_HOURS=

MAX_LOSS_PER_DAY=20.00
MAX_PROFIT_PER_DAY=0
MAX_TRADES_PER_DAY=50
DAILY_TRAILING_START=0
DAILY_TRAILING_LOCK=0
MAX_STAKE_PERCENT=0.02
MAX_CONSECUTIVE_LOSSES=7
MIN_STAKE=0.35
MAX_STAKE=100.00
USE_SOROS=false
SOROS_MAX_STEPS=1
SOROS_PROFIT_FACTOR=1.0
COOLDOWN_CANDLES=1
JOURNAL_DIR=logs

# Seguro por padrao. Com true, o bot so registra sinais e nao compra contratos.
DRY_RUN=true

# Para conta real, alem de DRY_RUN=false, isto precisa ser true.
ALLOW_REAL_TRADING=false

LOG_LEVEL=INFO
RECONNECT_DELAY_SECONDS=10
